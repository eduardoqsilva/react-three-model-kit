{
	"name": "react-three-model-kit",
	"version": "1.0.0",
	"description": "Biblioteca para gerenciamento de materiais PBR em modelos Three.js",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"lint": "tsc --noEmit"
	},
	"keywords": [
		"threejs",
		"react",
		"pbr",
		"materials",
		"gltf"
	],
	"author": "",
	"license": "ISC",
	"peerDependencies": {
		"react": ">=19",
		"three": ">=0.150.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": false
		},
		"three": {
			"optional": false
		}
	},
	"devDependencies": {
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"react": "19.2.3",
		"three": "^0.183.2",
		"@types/three": "^0.183.1",
		"tsup": "^8.5.1",
		"typescript": "^5.0.0",
		"@biomejs/biome": "2.2.0"
	}
}
